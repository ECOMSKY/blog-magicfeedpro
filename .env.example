# Production URL of the blog. Used for canonical / OG / sitemaps.
NEXT_PUBLIC_SITE_URL=https://blog.magicfeedpro.com

# Plausible analytics (privacy-first, no consent banner required in the EU).
# Set to the production hostname (no protocol).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=blog.magicfeedpro.com

# Newsletter (Resend Audience). Optional in dev — without these the API route
# accepts subscriptions but does not persist them.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Giscus comments (disabled until configured). Per-article opt-in via frontmatter `comments: true`.
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
